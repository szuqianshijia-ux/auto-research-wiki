# LLM Wiki 工作目录（包含 knowledge_bases/ 和 research_project/）
AUTO_RESEARCH_DIR=/path/to/auto_research

# LLM Wiki 应用状态文件路径
LLM_WIKI_APP_STATE=/path/to/.local/share/com.llmwiki.app/app-state.json

# LLM Wiki API Token（从应用设置中获取）
LLM_WIKI_API_TOKEN=your_api_token_here

# 项目 ID（从 LLM Wiki 项目注册表中获取）
EMBODIED_PROJECT_ID=your_embodied_project_id
VIBRATION_PROJECT_ID=your_vibration_project_id

# 当前活跃项目（embodied 或 vibration）
WIKI_PROJECT=embodied

# Wiki API 连接（默认 http://127.0.0.1:19828，通常无需修改）
# LLM_WIKI_API_BASE=http://127.0.0.1:19828

# 项目级 ID（直接覆盖，优先级高于 EMBODIED_PROJECT_ID）
# WIKI_PROJECT_ID=

# wiki_retrieval 知识库本地路径（用于离线图索引）
# WIKI_KB_PATH=/path/to/knowledge_base

# === LLM API（wiki_optimizer / vib_batch_ingest / wiki_retrieval 使用） ===
# 兼容 OpenAI 格式的 LLM API 端点（用于去重合并、社区摘要等）
LLM_API_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=claude-haiku-4-5-20251001

# === 论文下载器（可选） ===
# Unpaywall 需要真实邮箱（配置后自动启用 Unpaywall 源）
# UNPAYWALL_EMAIL=your@email.com
# Semantic Scholar API key（可选，无 key 仍可用但有速率限制）
# SEMANTIC_SCHOLAR_API_KEY=

# 推荐目录结构：
#   raw/
#   ├── sources/          ← LLM Wiki 索引范围（Markdown + 文档，不含 PDF）
#   │   ├── markdown/     ← MinerU 转换后的 Markdown（--add-to-sources 自动放这里）
#   │   └── papers/       ← 清单 .md 文件（可选）
#   └── pdfs/             ← 原始 PDF 存储（不被 LLM Wiki 索引）
#       └── papers/       ← download.py 下载目标（WIKI_PAPERS_BASE 指向这里）

# === MinerU PDF 转换（可选，需 GPU + magic-pdf[full]）===
# 是否在下载后自动转换 PDF（1=开启，0=关闭）。也可用 --convert 临时开启。
MINERU_ENABLED=0
# Markdown 输出目录（绝对路径）。未设置时自动使用 <project_root>/markdown/
# WIKI_MARKDOWN_DIR=/path/to/markdown
# 最低空闲显存阈值（MiB）。低于此值时跳过转换，避免与训练进程竞争 OOM。
# RTX 4090 D 跑训练时剩余约 3 GB → 低于默认 6 GB → 自动跳过。
MINERU_MIN_VRAM_MIB=6144
# 是否将转换后 Markdown 复制到 raw/sources/markdown/ 供 LLM Wiki 索引（1=开启）
MINERU_ADD_TO_SOURCES=0

# === 对话摘要同步（sync_notes_to_wiki.mjs 使用） ===
# 摘要源目录（默认：notes/chat_summaries/）
# NOTES_SRC_DIR=notes/chat_summaries
# 同步目标目录（默认从 AUTO_RESEARCH_DIR 推导）
# NOTES_DST_DIR=

# === 训练自动化（可选） ===
# 训练服务器
TRAINING_SERVER_HOST=your_training_server_ip
TRAINING_SERVER_USER=your_username
TRAINING_CHECKPOINT_DIR=/path/to/checkpoints

# WandB 集成（可选）
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=your_project_name

# === 进度追踪（可选） ===
MILESTONES_FILE=milestones.yaml
